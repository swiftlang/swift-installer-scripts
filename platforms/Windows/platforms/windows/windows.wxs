<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Language="1033"
      Manufacturer="!(loc.ManufacturerName)"
      Name="!(loc.Plt_ProductName_Windows)"
      UpgradeCode="$(WindowsPlatformUpgradeCode)"
      Version="$(NonSemVerProductVersion)"
      Scope="$(PackageScope)">

    <Property Id="INSTALLARM64SDK" Value="1" />
    <Property Id="INSTALLARM64REDIST" Value="1" />
    <Property Id="INSTALLAMD64SDK" Value="1" />
    <Property Id="INSTALLAMD64REDIST" Value="1" />
    <Property Id="INSTALLX86SDK" Value="1" />
    <Property Id="INSTALLX86REDIST" Value="1" />

    <Media Id="1" Cabinet="windows.cab" EmbedCab="$(ArePackageCabsEmbedded)" />
    <?if $(IncludeARM64) == True?>
      <Media Id="2" Cabinet="sdk.windows.arm64.cab" EmbedCab="$(ArePackageCabsEmbedded)" />
    <?endif?>
    <?if $(IncludeX64) == True?>
      <Media Id="3" Cabinet="sdk.windows.x64.cab" EmbedCab="$(ArePackageCabsEmbedded)" />
    <?endif?>
    <?if $(IncludeX86) == True?>
      <Media Id="4" Cabinet="sdk.windows.x86.cab" EmbedCab="$(ArePackageCabsEmbedded)" />
    <?endif?>

    <WixVariable Id="SideBySidePackageUpgradeCode" Value="$(WindowsPlatformUpgradeCode)" />
    <FeatureGroupRef Id="SideBySideUpgradeStrategy" />

    <!--
      └─ Swift
          └─ Platforms
              └─ Windows.platform
                  └─ Developer
                      ├─ Library
                      │   ├─ XCTest-$ProductVersion
                      │   │   └─ ...
                      │   └─ Testing-$ProductVersion
                      │       └─ ...
                      └─ SDKs
                          └─ Windows.sdk
                                  └─ ...
    -->
    <DirectoryRef Id="PlatformsVersioned">
      <Directory Id="WindowsPlatform" Name="Windows.platform">
        <Directory Name="Developer">
          <Directory Name="Library">
            <!-- XCTest -->
            <Directory Name="XCTest-$(ProductVersion)">
              <Directory Name="usr">
                <?if $(IncludeARM64) == True?>
                  <Directory Id="XCTest_usr_bin64a" Name="bin64a" DiskId="2" />
                <?endif?>
                <?if $(IncludeX64) == True?>
                  <Directory Id="XCTest_usr_bin64" Name="bin64" DiskId="3" />
                <?endif?>
                <?if $(IncludeX86) == True?>
                  <Directory Id="XCTest_usr_bin32" Name="bin32" DiskId="4" />
                <?endif?>
                <Directory Name="lib">
                  <Directory Name="swift">
                    <Directory Name="windows">
                      <?if $(IncludeARM64) == True?>
                        <Directory Id="XCTest_usr_lib_swift_windows_arm64" Name="aarch64" DiskId="2" />
                      <?endif?>
                      <?if $(IncludeX64) == True?>
                        <Directory Id="XCTest_usr_lib_swift_windows_x64" Name="x86_64" DiskId="3" />
                      <?endif?>
                      <?if $(IncludeX86) == True?>
                        <Directory Id="XCTest_usr_lib_swift_windows_x86" Name="i686" DiskId="4" />
                      <?endif?>
                      <Directory Id="XCTest.swiftmodule" Name="XCTest.swiftmodule" />
                    </Directory>
                  </Directory>
                </Directory>
              </Directory>
            </Directory>

            <!-- Testing -->
            <Directory Name="Testing-$(ProductVersion)">
              <Directory Name="usr">
                <?if $(IncludeARM64) == True?>
                  <Directory Id="Testing_usr_bin64a" Name="bin64a" DiskId="2" />
                <?endif?>
                <?if $(IncludeX64) == True?>
                  <Directory Id="Testing_usr_bin64" Name="bin64" DiskId="3" />
                <?endif?>
                <?if $(IncludeX86) == True?>
                  <Directory Id="Testing_usr_bin32" Name="bin32" DiskId="4" />
                <?endif?>
                <Directory Name="lib">
                  <Directory Name="swift">
                    <Directory Name="windows">
                      <Directory Id="_Testing_Foundation.swiftmodule" Name="_Testing_Foundation.swiftmodule" />
                      <Directory Id="_Testing_WinSDK.swiftmodule" Name="_Testing_WinSDK.swiftmodule" />
                      <?if $(IncludeARM64) == True?>
                        <Directory Id="Testing_usr_lib_swift_windows_arm64" Name="aarch64" DiskId="2" />
                      <?endif?>
                      <?if $(IncludeX64) == True?>
                        <Directory Id="Testing_usr_lib_swift_windows_x64" Name="x86_64" DiskId="3" />
                      <?endif?>
                      <?if $(IncludeX86) == True?>
                        <Directory Id="Testing_usr_lib_swift_windows_x86" Name="i686" DiskId="4" />
                      <?endif?>
                      <Directory Id="Testing.swiftcrossimport" Name="Testing.swiftcrossimport" />
                      <Directory Id="Testing.swiftmodule" Name="Testing.swiftmodule" />
                    </Directory>
                  </Directory>
                </Directory>
              </Directory>
            </Directory>
          </Directory>

          <Directory Name="SDKs">
            <!-- Windows.sdk -->
            <Directory Id="WindowsSDK" Name="Windows.sdk">
              <Directory Name="usr">
                <Directory Name="include">
                  <Directory Id="SDK_usr_include__foundation_unicode" Name="_foundation_unicode" DiskId="1" />
                  <Directory Id="SDK_usr_include__FoundationCShims" Name="_FoundationCShims" DiskId="1" />
                  <Directory Id="SDK_usr_include__FoundationInternationalizationData" Name="_FoundationInternationalizationData" DiskId="1" />
                  <Directory Id="SDK_usr_include_Block" Name="Block" DiskId="1" />
                  <Directory Id="SDK_usr_include_dispatch" Name="dispatch" DiskId="1" />
                  <Directory Id="SDK_usr_include_os" Name="os" DiskId="1" />
                  <Directory Name="swift">
                    <Directory Id="SDK_usr_include_swift_SwiftRemoteMirror" Name="SwiftRemoteMirror" DiskId="1" />
                  </Directory>
                </Directory>
                <Directory Name="lib">
                  <Directory Name="swift">
                    <Directory Id="SDK_usr_lib_swift_apinotes" Name="apinotes" DiskId="1" />
                    <Directory Id="SDK_usr_lib_swift_shims" Name="shims" DiskId="1" />
                    <Directory Id="SDK_usr_lib_swift_windows" Name="windows">
                      <?foreach ModuleName in $(SDKSwiftModules)?>
                        <Directory Id="$(ModuleName).swiftmodule" Name="$(ModuleName).swiftmodule" />
                      <?endforeach?>
                      <?if $(IncludeARM64) == True?>
                        <Directory Id="SDK_usr_lib_swift_windows_arm64" Name="aarch64" DiskId="2" />
                      <?endif?>
                      <?if $(IncludeX64) == True?>
                        <Directory Id="SDK_usr_lib_swift_windows_x64" Name="x86_64" DiskId="3" />
                      <?endif?>
                      <?if $(IncludeX86) == True?>
                        <Directory Id="SDK_usr_lib_swift_windows_x86" Name="i686" DiskId="4" />
                      <?endif?>
                    </Directory>
                  </Directory>
                  <Directory Name="swift_static">
                    <Directory Id="SDK_usr_lib_swift_static_winows" Name="windows">
                      <?foreach ModuleName in $(SDKSwiftModules)?>
                        <Directory Id="lib$(ModuleName).swiftmodule" Name="$(ModuleName).swiftmodule" />
                      <?endforeach?>
                      <?if $(IncludeARM64) == True?>
                        <Directory Id="SDK_usr_lib_swift_static_windows_arm64" Name="aarch64" DiskId="2" />
                      <?endif?>
                      <?if $(IncludeX64) == True?>
                        <Directory Id="SDK_usr_lib_swift_static_windows_x64" Name="x86_64" DiskId="3" />
                      <?endif?>
                      <?if $(IncludeX86) == True?>
                        <Directory Id="SDK_usr_lib_swift_static_windows_x86" Name="i686" DiskId="4" />
                      <?endif?>
                    </Directory>
                  </Directory>
                </Directory>
                <Directory Id="SDK_usr_share" Name="share" DiskId="1" />
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </DirectoryRef>

    <!-- XCTest -->
    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="XCTest.arm64">
        <File Directory="XCTest.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File Directory="XCTest.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\aarch64-unknown-windows-msvc.swiftmodule" />

        <File Directory="XCTest_usr_bin64a" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\bin64a\XCTest.dll" />
        <File Directory="XCTest_usr_lib_swift_windows_arm64" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\aarch64\XCTest.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="XCTest.x64">
        <File Directory="XCTest.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File Directory="XCTest.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\x86_64-unknown-windows-msvc.swiftmodule" />

        <File Directory="XCTest_usr_bin64" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\bin64\XCTest.dll" />
        <File Directory="XCTest_usr_lib_swift_windows_x64" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\x86_64\XCTest.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="XCTest.x86">
        <File Directory="XCTest.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\i686-unknown-windows-msvc.swiftdoc" />
        <File Directory="XCTest.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\XCTest.swiftmodule\i686-unknown-windows-msvc.swiftmodule" />

        <File Directory="XCTest_usr_bin32" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\bin32\XCTest.dll" />
        <File Directory="XCTest_usr_lib_swift_windows_x86" Source="$(PlatformRoot)\Developer\Library\XCTest-$(ProductVersion)\usr\lib\swift\windows\i686\XCTest.lib" />
      </ComponentGroup>
    <?endif?>

    <!-- Testing -->
    <ComponentGroup Id="Testing">
      <File Directory="Testing.swiftcrossimport" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftcrossimport\Foundation.swiftoverlay" />
      <File Directory="Testing.swiftcrossimport" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftcrossimport\WinSDK.swiftoverlay" />
    </ComponentGroup>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="Testing.arm64">
        <File Directory="Testing.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File Directory="Testing.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\aarch64-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_Foundation.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_Foundation.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\aarch64-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="2" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\aarch64-unknown-windows-msvc.swiftinterface" />

        <File Directory="Testing_usr_bin64a" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64a\Testing.dll" />
        <File Directory="Testing_usr_bin64a" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64a\_Testing_Foundation.dll" />
        <File Directory="Testing_usr_bin64a" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64a\_Testing_WinSDK.dll" />
        <File Directory="Testing_usr_bin64a" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64a\_TestingInterop.dll" />

        <File Directory="Testing_usr_lib_swift_windows_arm64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\aarch64\Testing.lib" />
        <File Directory="Testing_usr_lib_swift_windows_arm64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\aarch64\_Testing_Foundation.lib" />
        <File Directory="Testing_usr_lib_swift_windows_arm64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\aarch64\_Testing_WinSDK.lib" />
        <File Directory="Testing_usr_lib_swift_windows_arm64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\aarch64\_TestingInterop.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="Testing.x64">
        <File Directory="Testing_usr_bin64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64\Testing.dll" />
        <File Directory="Testing_usr_bin64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64\_Testing_Foundation.dll" />
        <File Directory="Testing_usr_bin64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64\_Testing_WinSDK.dll" />
        <File Directory="Testing_usr_bin64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin64\_TestingInterop.dll" />

        <File Directory="Testing_usr_lib_swift_windows_x64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\x86_64\Testing.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\x86_64\_Testing_Foundation.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\x86_64\_Testing_WinSDK.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x64" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\x86_64\_TestingInterop.lib" />

        <File Directory="Testing.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File Directory="Testing.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\x86_64-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_Foundation.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_Foundation.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\x86_64-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="3" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\x86_64-unknown-windows-msvc.swiftinterface" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="Testing.x86">
        <File Directory="Testing_usr_bin32" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin32\Testing.dll" />
        <File Directory="Testing_usr_bin32" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin32\_Testing_Foundation.dll" />
        <File Directory="Testing_usr_bin32" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin32\_Testing_WinSDK.dll" />
        <File Directory="Testing_usr_bin32" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\bin32\_TestingInterop.dll" />

        <File Directory="Testing_usr_lib_swift_windows_x86" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\i686\Testing.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x86" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\i686\_Testing_Foundation.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x86" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\i686\_Testing_WinSDK.lib" />
        <File Directory="Testing_usr_lib_swift_windows_x86" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\i686\_TestingInterop.lib" />

        <File Directory="Testing.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\i686-unknown-windows-msvc.swiftdoc" />
        <File Directory="Testing.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\Testing.swiftmodule\i686-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_Foundation.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\i686-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_Foundation.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_Foundation.swiftmodule\i686-unknown-windows-msvc.swiftinterface" />

        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\i686-unknown-windows-msvc.swiftdoc" />
        <File Directory="_Testing_WinSDK.swiftmodule" DiskId="4" Source="$(PlatformRoot)\Developer\Library\Testing-$(ProductVersion)\usr\lib\swift\windows\_Testing_WinSDK.swiftmodule\i686-unknown-windows-msvc.swiftinterface" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="_FoundationUnicode.arm64" Directory="SDK_usr_lib_swift_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\aarch64\_FoundationICU.lib" />
      </ComponentGroup>

      <ComponentGroup Id="lib_FoundationUnicode.arm64" Directory="SDK_usr_lib_swift_static_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\_FoundationICU.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="_FoundationUnicode.x64" Directory="SDK_usr_lib_swift_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\x86_64\_FoundationICU.lib" />
      </ComponentGroup>

      <ComponentGroup Id="lib_FoundationUnicode.x64" Directory="SDK_usr_lib_swift_static_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\x86_64\_FoundationICU.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="_FoundationUnicode.x86" Directory="SDK_usr_lib_swift_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\i686\_FoundationICU.lib" />
      </ComponentGroup>

      <ComponentGroup Id="lib_FoundationUnicode.x86" Directory="SDK_usr_lib_swift_static_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\i686\_FoundationICU.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="lib_FoundationCShims.arm64" Directory="SDK_usr_lib_swift_static_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\_FoundationCShims.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="lib_FoundationCShims.x64" Directory="SDK_usr_lib_swift_static_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\x86_64\_FoundationCShims.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="lib_FoundationCShims.x86" Directory="SDK_usr_lib_swift_static_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\i686\_FoundationCShims.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="lib_FoundationInternationalizationData.arm64" Directory="SDK_usr_lib_swift_static_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\_FoundationInternationalizationData.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="lib_FoundationInternationalizationData.x64" Directory="SDK_usr_lib_swift_static_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\x86_64\_FoundationInternationalizationData.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="lib_FoundationInternationalizationData.x86" Directory="SDK_usr_lib_swift_static_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\i686\_FoundationInternationalizationData.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="BlocksRuntime.arm64" Directory="SDK_usr_lib_swift_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\aarch64\BlocksRuntime.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libBlocksRuntime.arm64" Directory="SDK_usr_lib_swift_static_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\BlocksRuntime.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="BlocksRuntime.x64" Directory="SDK_usr_lib_swift_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\x86_64\BlocksRuntime.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libBlocksRuntime.x64" Directory="SDK_usr_lib_swift_static_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\x86_64\BlocksRuntime.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX86) == True?>
      <ComponentGroup Id="BlocksRuntime.x86" Directory="SDK_usr_lib_swift_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\i686\BlocksRuntime.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libBlocksRuntime.x86" Directory="SDK_usr_lib_swift_static_windows_x86">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\i686\BlocksRuntime.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeARM64) == True?>
      <ComponentGroup Id="dispatch.arm64" Directory="SDK_usr_lib_swift_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\aarch64\dispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libdispatch.arm64" Directory="SDK_usr_lib_swift_static_windows_arm64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\dispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="Dispatch.arm64" Directory="Dispatch.swiftmodule">
        <File DiskId="2" Source="$(SDKRoot)\usr\lib\swift\windows\Dispatch.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File DiskId="2" Source="$(SDKRoot)\usr\lib\swift\windows\Dispatch.swiftmodule\aarch64-unknown-windows-msvc.swiftmodule" />

        <File Directory="SDK_usr_lib_swift_windows_arm64" Source="$(SDKRoot)\usr\lib\swift\windows\aarch64\swiftDispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libDispatch.arm64" Directory="libDispatch.swiftmodule">
        <File DiskId="2" Source="$(SDKRoot)\usr\lib\swift_static\windows\Dispatch.swiftmodule\aarch64-unknown-windows-msvc.swiftdoc" />
        <File DiskId="2" Source="$(SDKRoot)\usr\lib\swift_static\windows\Dispatch.swiftmodule\aarch64-unknown-windows-msvc.swiftmodule" />

        <File Directory="SDK_usr_lib_swift_static_windows_arm64" Source="$(SDKRoot)\usr\lib\swift_static\windows\aarch64\libswiftDispatch.lib" />
      </ComponentGroup>
    <?endif?>

    <?if $(IncludeX64) == True?>
      <ComponentGroup Id="dispatch.x64" Directory="SDK_usr_lib_swift_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift\windows\x86_64\dispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libdispatch.x64" Directory="SDK_usr_lib_swift_static_windows_x64">
        <File Source="$(SDKRoot)\usr\lib\swift_static\windows\x86_64\dispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="Dispatch.x64" Directory="Dispatch.swiftmodule">
        <File DiskId="3" Source="$(SDKRoot)\usr\lib\swift\windows\Dispatch.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File DiskId="3" Source="$(SDKRoot)\usr\lib\swift\windows\Dispatch.swiftmodule\x86_64-unknown-windows-msvc.swiftmodule" />

        <File Directory="SDK_usr_lib_swift_windows_x64" Source="$(SDKRoot)\usr\lib\swift\windows\x86_64\swiftDispatch.lib" />
      </ComponentGroup>

      <ComponentGroup Id="libDispatch.x64" Directory="libDispatch.swiftmodule">
        <File DiskId="3" Source="$(SDKRoot)\usr\lib\swift_static\windows\Dispatch.swiftmodule\x86_64-unknown-windows-msvc.swiftdoc" />
        <File DiskId="3" Source="$(SDKRoot)\usr\lib\swift_static\windows\Dispatch.swiftmodule\x86_64-unknown-windows-msvc.swiftmodule" />

