<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?if $(RuntimeLibraryInstallationMode) = "shared" ?>
    <?if $(ProductArchitecture) = "x86" ?>
      <?define ModuleID = "53C54287-A59A-4828-A526-4F64E00B340E" ?>
    <?elseif $(ProductArchitecture) = "amd64" ?>
      <?define ModuleID = "F84DDCA4-72B0-42AB-9316-21DBAB241540" ?>
    <?elseif $(ProductArchitecture) = "arm64" ?>
      <?define ModuleID = "0439EF46-C6C2-43DF-A5A7-8F4C3F5C64A7" ?>
    <?endif?>
  <?else?>
    <?if $(ProductArchitecture) = "x86" ?>
      <?define ModuleID = "39ADEBE1-D922-5786-85E1-75FF6BA8C710" ?>
    <?elseif $(ProductArchitecture) = "amd64" ?>
      <?define ModuleID = "F88CB2FA-C383-5F80-BF2A-6BB371708285" ?>
    <?elseif $(ProductArchitecture) = "arm64" ?>
      <?define ModuleID = "95BF5AF5-32E2-525A-8121-46A8471E1893" ?>
    <?endif?>
  <?endif?>

  <?if $(ProductArchitecture) = "x86" ?>
    <?define RuntimeDirectoryComponentGuidGenerationSeed = "D3021274-DCA3-4369-82D3-B6CEE436A3FC" ?>
    <?define BlocksRuntimeComponentGuid = "362C16EB-906F-43F4-AA77-7F1667DB14CA" ?>
    <?define DispatchComponentGuid = "A253787E-1B91-4FFA-8CF4-7E3CEFE5A2FE" ?>
    <?define RuntimeRoot = "$(WindowsRuntimeX86)" ?>
  <?elseif $(ProductArchitecture) = "amd64" ?>
    <?define RuntimeDirectoryComponentGuidGenerationSeed = "639A8564-3505-4424-BA2F-449AAF743A90" ?>
    <?define BlocksRuntimeComponentGuid = "D00EC465-CBF9-4297-A2AE-E51A24E01C22" ?>
    <?define DispatchComponentGuid = "24093657-5194-4886-9E69-729621137013" ?>
    <?define RuntimeRoot = "$(WindowsRuntimeX64)" ?>
  <?elseif $(ProductArchitecture) = "arm64" ?>
    <?define RuntimeDirectoryComponentGuidGenerationSeed = "F8BF026F-8E3F-42B5-A5E7-E0A4D186EDF3" ?>
    <?define BlocksRuntimeComponentGuid = "B8A5D4E6-087E-4BF2-963A-48395F360DAE" ?>
    <?define DispatchComponentGuid = "DC24B385-7582-4A6B-85B3-A50A0B0C706E" ?>
    <?define RuntimeRoot = "$(WindowsRuntimeARM64)" ?>
  <?endif?>

  <Module Guid="$(ModuleID)" Id="swift_runtime" Language="0" Version="$(NonSemVerProductVersion)">
    <Directory Id="RUNTIMEDIR_$(ProductArchitecture)" ComponentGuidGenerationSeed="$(RuntimeDirectoryComponentGuidGenerationSeed)">
      <?if $(RuntimeLibraryInstallationMode) = "private" ?>
        <?foreach RuntimeLibrary in $(StaticRuntimeDependencies)?>
          <Directory Id="RUNTIMEDIR_$(ProductArchitecture)_$(RuntimeLibrary)" Name="$(RuntimeLibrary)">
            <File Id="$(RuntimeLibrary)_$(ProductArchitecture)" Source="$(RuntimeRoot)\usr\bin\$(RuntimeLibrary).dll" />
          </Directory>
        <?endforeach?>
      <?else?>
        <?foreach RuntimeLibrary in $(StaticRuntimeDependencies)?>
          <?if $(RuntimeLibrary) = "BlocksRuntime" ?>
            <Component Id="C_$(RuntimeLibrary)" Guid="$(BlocksRuntimeComponentGuid)">
              <File Id="M_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).manifest" />
              <File Id="G_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).cat" />
              <File Id="F_$(RuntimeLibrary)"
                    Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).dll"
                    KeyPath="yes"
                    Assembly="win32"
                    AssemblyManifest="M_$(RuntimeLibrary)" />
            </Component>
          <?elseif $(RuntimeLibrary) = "dispatch" ?>
            <Component Id="C_$(RuntimeLibrary)" Guid="$(DispatchComponentGuid)">
              <File Id="M_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).manifest" />
              <File Id="G_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).cat" />
              <File Id="F_$(RuntimeLibrary)"
                    Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).dll"
                    KeyPath="yes"
                    Assembly="win32"
                    AssemblyManifest="M_$(RuntimeLibrary)" />
            </Component>
          <?else?>
            <Component Id="C_$(RuntimeLibrary)">
              <File Id="M_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).manifest" />
              <File Id="G_$(RuntimeLibrary)" Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).cat" />
              <File Id="F_$(RuntimeLibrary)"
                    Source="$(RuntimeWin32AssemblyRoot)\$(RuntimeLibrary)\$(RuntimeLibrary).dll"
                    KeyPath="yes"
                    Assembly="win32"
                    AssemblyManifest="M_$(RuntimeLibrary)" />
            </Component>
          <?endif?>
        <?endforeach?>
      <?endif?>
    </Directory>
  </Module>
</Wix>
