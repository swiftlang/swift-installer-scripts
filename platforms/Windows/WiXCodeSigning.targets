<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <SignOutput Condition=" '$(SignOutput)' == '' ">false</SignOutput>
    <SignOutput>$(SignOutput)</SignOutput>
    <SignToolVerbose Condition=" '$(SignToolVerbose)' == '' ">false</SignToolVerbose>
  </PropertyGroup>

  <Target Name="FindWindowsSDK">
    <PropertyGroup>
      <WindowsKitsRoot Condition=" '$(WindowsKitsRoot)' == '' ">$([MSBuild]::GetRegistryValueFromView('HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Kits\Installed Roots', 'KitsRoot10', null, RegistryView.Registry32, RegistryView.Default))</WindowsKitsRoot>
      <WindowsKitsRoot Condition=" '$(WindowsKitsRoot)' == '' ">$([MSBuild]::GetRegistryValueFromView('HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Kits\Installed Roots', 'KitsRoot81', null, RegistryView.Registry32, RegistryView.Default))</WindowsKitsRoot>
      <WindowsKitsRoot Condition=" '$(WindowsKitsRoot)' == '' ">$([MSBuild]::GetRegistryValueFromView('HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Kits\Installed Roots', 'KitsRoot', null, RegistryView.Registry32, RegistryView.Default))</WindowsKitsRoot>
      <WindowsSDKToolArchitecture Condition=" '$(WindowsSDKToolArchitecture)' == '' AND '$(PROCESSOR_ARCHITECTURE)' == 'ARM64' ">arm64</WindowsSDKToolArchitecture>
      <WindowsSDKToolArchitecture Condition=" '$(WindowsSDKToolArchitecture)' == '' ">x64</WindowsSDKToolArchitecture>
      <WindowsSDKToolsPath Condition=" '$(WindowsSDKToolsPath)' != '' AND !HasTrailingSlash('$(WindowsSDKToolsPath)') ">$(WindowsSDKToolsPath)\</WindowsSDKToolsPath>
    </PropertyGroup>

    <ItemGroup Condition=" '$(WindowsSDKToolsPath)' == '' ">
      <_WindowsSDKToolVersion Include="10.0.26100.0" />
      <_WindowsSDKToolVersion Include="10.0.25398.0" />
      <_WindowsSDKToolVersion Include="10.0.22621.0" />
      <_WindowsSDKToolVersion Include="10.0.22000.0" />
      <_WindowsSDKToolVersion Include="10.0.20348.0" />
      <_WindowsSDKToolVersion Include="10.0.19041.0" />
      <_WindowsSDKToolVersion Include="10.0.18362.0" />
      <_WindowsSDKToolVersion Include="10.0.17763.0" />
      <_WindowsSDKToolVersion Include="10.0.17134.0" />
      <_WindowsSDKToolVersion Include="10.0.16299.0" />
      <_WindowsSDKToolVersion Include="10.0.15063.0" />
      <_WindowsSDKToolVersion Include="10.0.14393.0" />
      <_WindowsSDKToolVersion Include="10.0.10586.0" />
      <_WindowsSDKToolVersion Include="10.0.10240.0" />
      <_WindowsSDKToolCandidateFile
          Include="$(WindowsKitsRoot)bin\*\$(WindowsSDKToolArchitecture)\mt.exe"
          Condition=" '$(WindowsKitsRoot)' != '' " />
      <_WindowsSDKToolCandidate
          Include="@(_WindowsSDKToolVersion->'$(WindowsKitsRoot)bin\%(Identity)\$(WindowsSDKToolArchitecture)\')"
          Condition=" '$(WindowsKitsRoot)' != '' " />
      <_WindowsSDKToolCandidate
          Include="@(_WindowsSDKToolCandidateFile->'%(RootDir)%(Directory)')" />
      <_WindowsSDKToolCandidate
          Remove="@(_WindowsSDKToolCandidate)"
          Condition="!Exists('%(_WindowsSDKToolCandidate.Identity)')" />
    </ItemGroup>

    <PropertyGroup>
      <_WindowsSDKToolCandidates>@(_WindowsSDKToolCandidate, ';')</_WindowsSDKToolCandidates>
      <WindowsSDKToolsPath
          Condition=" '$(WindowsSDKToolsPath)' == '' AND '$(_WindowsSDKToolCandidates)' != '' ">$([System.String]::Copy('$(_WindowsSDKToolCandidates)').Split(';').GetValue(0))</WindowsSDKToolsPath>
      <WindowsSDKToolsPath
          Condition=" '$(WindowsSDKToolsPath)' == '' AND '$(WindowsKitsRoot)' != '' AND Exists('$(WindowsKitsRoot)bin\$(WindowsSDKToolArchitecture)\')">$(WindowsKitsRoot)bin\$(WindowsSDKToolArchitecture)\</WindowsSDKToolsPath>
    </PropertyGroup>
  </Target>

  <Target Name="FindSignTool" DependsOnTargets="FindWindowsSDK">
    <PropertyGroup>
      <SignToolPath Condition=" '$(SignToolPath)' == '' ">$(WindowsSDKToolsPath)</SignToolPath>
      <SignToolPath Condition=" '$(SignToolPath)' != '' AND !HasTrailingSlash('$(SignToolPath)') ">$(SignToolPath)\</SignToolPath>
      <VerboseFlag Condition=" '$(SignToolVerbose)' == 'true' ">/v </VerboseFlag>
      <VerboseFlag Condition=" '$(SignToolVerbose)' != 'true' "></VerboseFlag>

      <!-- Microsoft recommends using their timestamp server for trusted signing: https://learn.microsoft.com/en-us/azure/trusted-signing/how-to-signing-integrations#:~:text=Trusted%20Signing%20certificates,microsoft.com/-->
      <SignTool Condition=" '$(AzureSignMetadata)' != '' ">"$(SignToolPath)signtool.exe" sign $(VerboseFlag)/tr http://timestamp.acs.microsoft.com /fd sha256 /td sha256 /dlib "$(AzureSignDlib)" /dmdf "$(AzureSignMetadata)"</SignTool>
      <SignTool Condition=" '$(AzureSignMetadata)' == '' ">"$(SignToolPath)signtool.exe" sign $(VerboseFlag)/tr http://timestamp.digicert.com /fd sha256 /td sha256 /f "$(CERTIFICATE)" /p "$(PASSPHRASE)" </SignTool>
    </PropertyGroup>
  </Target>

  <Target Name="SignCabs" DependsOnTargets="FindSignTool">
    <Exec Command="$(SignTool) &quot;%(SignCabs.FullPath)&quot;" />
  </Target>

  <Target Name="SignMsi" DependsOnTargets="FindSignTool">
    <Exec Command="$(SignTool) &quot;%(SignMsi.FullPath)&quot;" />
  </Target>

  <Target Name="SignMsm" DependsOnTargets="FindSignTool">
    <Exec Command="$(SignTool) &quot;%(SignMsm.FullPath)&quot;" />
  </Target>

  <Target Name="SignBundleEngine" DependsOnTargets="FindSignTool">
    <Exec Command="$(SignTool) &quot;@(SignBundleEngine)&quot;" />
  </Target>

  <Target Name="SignBundle" DependsOnTargets="FindSignTool">
    <Exec Command="$(SignTool) &quot;@(SignBundle)&quot;" />
  </Target>
</Project>
